{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ngx-recaptcha-v3": {
      "projectType": "library",
      "root": "projects/ngx-recaptcha-v3",
      "sourceRoot": "projects/ngx-recaptcha-v3/src",
      "prefix": "ng",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ngx-recaptcha-v3/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngx-recaptcha-v3/tsconfig.lib.json"
            }
          }
        }
      }
    },
    "playground": {
      "projectType": "application",
      "root": "projects/playground",
      "sourceRoot": "projects/playground/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/playground",
            "index": "projects/playground/src/index.html",
            "browser": "projects/playground/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "projects/playground/tsconfig.app.json",
            "optimization": {
              "scripts": true,
              "styles": true,
              "fonts": {
                "inline": false
              }
            }
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "buildTarget": "playground:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "playground:build:production"
            },
 "development": {
              "buildTarget": "playground:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
